# ─────────────────────────────────────────────────────────────────────────
# GoHighLevel (LeadConnector) — server-side only. Copy to .env.local and fill.
# ─────────────────────────────────────────────────────────────────────────

# Private Integration token (Settings → Private Integrations in your GHL sub-account).
# Scopes needed: contacts.write, contacts/notes.write, opportunities.write (if used).
GHL_API_TOKEN=

# The sub-account (location) id this funnel belongs to.
GHL_LOCATION_ID=

# ─── Calendar IDs (one per route) ───
# Each value may be a full booking URL (e.g.
#   https://api.leadconnectorhq.com/widget/bookings/1on1-interview-w-christina )
# OR a bare calendar id (wrapped in .../widget/booking/<id> automatically).
GHL_CALENDAR_BPM=
# NOTE: BOTH 1:1 routes (oneonone + the owner/producer "priority" tier) are
# HARDCODED to Christina's calendar in lib/routes.ts (forceCalendarUrl) so Tish's
# calendar never surfaces on the qualifier. These two env vars are IGNORED for
# calendar selection — leaving them set does nothing. To change the 1:1 calendar,
# edit CHRISTINA_1ON1_URL in lib/routes.ts.
GHL_CALENDAR_1ON1=
GHL_CALENDAR_TISH=
# "Not a fit" books nothing — leave unset.
GHL_CALENDAR_NOTFIT=

# ─── Tags applied per route (optional — sensible defaults are used if blank) ───
GHL_TAG_BPM=Qualifier - Group BPM
GHL_TAG_1ON1=Qualifier - 1:1 Interview
GHL_TAG_TISH=Qualifier - 1:1 with Tish
GHL_TAG_NOTFIT=Qualifier - Not a Fit

# ─── Optional: "free resources" link shown on the not-a-fit screen ───
# If set, the decline screen shows an "Explore free resources →" button.
NOTFIT_RESOURCE_URL=

# ─── Optional: pipeline placement ───
# If set, finishing the quiz creates an opportunity in this pipeline at the
# stage matching the route. Leave blank to skip pipeline placement entirely.
GHL_PIPELINE_ID=
GHL_STAGE_BPM=
GHL_STAGE_ONEONONE=
GHL_STAGE_TISH=

# ─── Optional: tune the 1:1 cutoff (defaults to 60) ───
QUALIFIER_THRESHOLD=60
